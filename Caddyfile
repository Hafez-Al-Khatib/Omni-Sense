# Caddyfile — Omni-Sense production reverse proxy
# Requires wildcard DNS: *.{$OMNI_DOMAIN} → 65.109.163.224
#
# Generate bcrypt hashes for basic_auth:
#   docker run --rm caddy:2 caddy hash-password --plaintext '<pwd>'

# ── EEP API Gateway ──
eep.{$OMNI_DOMAIN} {
    reverse_proxy eep:8000
    encode gzip
    request_body {
        max_size 10MB
    }
}

# ── Grafana Dashboards ──
grafana.{$OMNI_DOMAIN} {
    reverse_proxy grafana:3000
    encode gzip
}

# ── Prometheus Metrics (basic-auth protected) ──
prometheus.{$OMNI_DOMAIN} {
    reverse_proxy prometheus:9090
    encode gzip

    basic_auth {
        admin {$OMNI_PROM_BASIC_HASH}
    }
}

# ── MLflow Tracking (basic-auth protected) ──
mlflow.{$OMNI_DOMAIN} {
    reverse_proxy mlflow:5000
    encode gzip

    basic_auth {
        admin {$OMNI_MLFLOW_BASIC_HASH}
    }
}

# ── Operations Console (static production dashboard) ──
ops.{$OMNI_DOMAIN} {
    root * /srv/dashboard
    encode gzip

    basic_auth {
        admin {$OMNI_DASHBOARD_HASH}
    }

    # Live API proxy (strips /api prefix)
    handle_path /api/* {
        reverse_proxy live-api:8080
    }

    # Static data endpoints (before SPA fallback)
    handle_path /data/* {
        root * /srv/dashboard/data
        file_server
    }

    try_files {path} /index.html
    file_server
}

# ── Live API (dedicated subdomain, no SPA conflicts) ──
api.{$OMNI_DOMAIN} {
    reverse_proxy live-api:8080
    encode gzip
}

# ── MQTT WebSocket proxy (for browser dashboard) ──
mqtt.{$OMNI_DOMAIN} {
    reverse_proxy mqtt-broker:9001 {
        transport http {
            versions 1.1
        }
    }
}

# ── Web UI (static upload / analysis frontend) ──
ui.{$OMNI_DOMAIN} {
    root * /srv/web-ui
    file_server
    encode gzip
}
