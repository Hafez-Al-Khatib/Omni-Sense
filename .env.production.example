# .env.production — Production environment variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git (it is gitignored).
#
# Generate bcrypt hashes for Caddy basic_auth:
#   docker run --rm caddy:2 caddy hash-password --plaintext '<your-password>'
#   Output: $2a$14$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   In this file, escape $ as $$: $$2a$$14$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DNS ──────────────────────────────────────────────────────────────────────
# Must be a domain with wildcard DNS support (Cloudflare recommended).
# DuckDNS free tier does NOT support wildcards like *.omnisense-demo.duckdns.org
OMNI_DOMAIN=yourdomain.com

# ── Caddy basic auth hashes (escape every $ as $$) ──────────────────────────
OMNI_PROM_BASIC_HASH=$$2a$$14$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OMNI_MLFLOW_BASIC_HASH=$$2a$$14$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=omni
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=omnisense

# ── MQTT ────────────────────────────────────────────────────────────────────
MQTT_PASSWORD=your-mqtt-password

# ── Rate Limiting ───────────────────────────────────────────────────────────
OMNI_RATE_LIMIT=100/minute
