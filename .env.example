# ─── Omni-Sense Global Environment Example ────────────────────────────────────
# Copy this file to .env and tune for your local/production environment.

# ── Service Authentication ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate with: openssl rand -base64 12
GRAFANA_ADMIN_PASSWORD=change-me-grafana-local-only

# ── TimescaleDB (Postgres) ────────────────────────────────────────────────────
POSTGRES_USER=omni
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change-me-postgres-local-only
POSTGRES_DB=omnisense

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_PASSWORD=your_mqtt_password_here

# ── EEP rate-limit override (per-IP per-window) ───────────────────────────────
# format: "count/duration" e.g. "10/minute"
OMNI_RATE_LIMIT=5/minute

# ── IEP URLs (Internal Endpoint routing) ──────────────────────────────────────
# Only override if running services outside docker-compose
OMNI_IEP2_URL=http://iep2:8002
OMNI_IEP3_URL=http://iep3:8003
OMNI_IEP4_URL=http://iep4:8004

# ── External APIs ─────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...
# TWILIO_CREW_NUMBERS={"crew-01": "+9613123456"}
