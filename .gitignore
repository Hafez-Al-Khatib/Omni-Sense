*.xlsx
*.xls
~$*

# Test / Coverage
.coverage
htmlcov/
.pytest_cache/

# Grafana
monitoring/grafana/data/

*.zip

# Personal scratch notes (NEVER use *.md catchall — that hides README, MODEL_REPORT, etc.)
NOTES_LOCAL.md
SCRATCH.md
TODO_LOCAL.md

.claude/

