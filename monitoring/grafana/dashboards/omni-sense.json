        {
            "title": "OOD Isolation Forest Score (Input Drift Proxy)",
            "type": "gauge",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "ood_isolation_forest_score",
                    "legendFormat": "IF Score"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": -0.2
                            },
                            {
                                "color": "green",
                                "value": 0
                            }
                        ]
                    },
                    "min": -0.5,
                    "max": 0.5
                }
            }
        },
        {
            "title": "XGBoost Prediction Confidence Distribution",
            "type": "histogram",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "rate(xgboost_prediction_confidence_bucket[10m])",
                    "legendFormat": "{{le}}"
