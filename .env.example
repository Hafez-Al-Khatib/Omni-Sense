# ──────────────────────────────────────────────────────────────────────────────
# Omni-Sense — local development environment
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values below.
# `.env` is git-ignored; DO NOT commit real credentials.
#
#   cp .env.example .env
#   docker compose up
# ──────────────────────────────────────────────────────────────────────────────

# ── Grafana admin (dashboard login) ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate a strong password for local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
GRAFANA_ADMIN_PASSWORD=change-me-grafana-local-only

# ── TimescaleDB (Postgres) ────────────────────────────────────────────────────
POSTGRES_USER=omni
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=your_secure_password_here
MQTT_PASSWORD=your_mqtt_password_here
POSTGRES_DB=omnisense

# ── EEP rate-limit override (per-IP per-window) ───────────────────────────────
OMNI_RATE_LIMIT=5/minute

# ── CORS allow-list (JSON array, used by pydantic-settings) ───────────────────
# For production, point this at the real dashboard host(s):
# OMNI_CORS_ORIGINS=["https://dashboard.omni-sense.io"]
OMNI_CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ── OPC-UA gateway (set to false to use the synthetic pressure simulator) ─────
OMNI_USE_STUB_GATEWAY=true
# OPCUA_ENDPOINT=opc.tcp://plc.example.internal:4840
# OPCUA_NODE_IDS={"pump1_pressure": "ns=2;i=42", "pump1_flow": "ns=2;i=43"}

# ── Twilio (CMMS SMS dispatch) — optional, leave blank to disable ─────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_CREW_NUMBERS={"plumbing": "+15551234567", "electrical": "+15557654321"}

# ── Audit HMAC key (generate once and keep stable across restarts!) ──────────
# Run:  python -c "import secrets; print(secrets.token_hex(32))"
OMNI_AUDIT_HMAC_KEY=
